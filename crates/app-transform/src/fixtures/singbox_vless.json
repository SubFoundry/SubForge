{
  "outbounds": [
    {
      "type": "selector",
      "tag": "select",
      "outbounds": [
        "auto",
        "VLESS-US"
      ],
      "default": "auto"
    },
    {
      "type": "urltest",
      "tag": "auto",
      "outbounds": [
        "VLESS-US"
      ],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "5m",
      "tolerance": 50
    },
    {
      "type": "vless",
      "tag": "VLESS-US",
      "server": "vless-us.example.com",
      "server_port": 443,
      "uuid": "22222222-2222-2222-2222-222222222222",
      "flow": "xtls-rprx-vision",
      "network": "tcp",
      "tls": {
        "enabled": true,
        "server_name": "tls.example.com"
      },
      "transport": {
        "type": "grpc",
        "service_name": "vless-grpc"
      }
    }
  ]
}
